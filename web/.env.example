# Base de datos (Backend) — p. ej. Neon/Supabase Postgres
DATABASE_URL=

# Sesión (Security) — mínimo 32 caracteres aleatorios
SESSION_SECRET=

# Email transaccional para la solicitud de pedido/presupuesto (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@nunezgil.com

# Público
NEXT_PUBLIC_SITE_URL=https://nunezgil.com
NEXT_PUBLIC_GA_ID=G-RWL5CKME4Q

# Base del CDN de imágenes del catálogo (Backend).
# Hoy apunta al proveedor saliente (Movatec/workcrm). Tras migrar las fotos a
# Vercel Blob / R2, cambiar SOLO este valor (y el remotePattern de next.config.mjs).
